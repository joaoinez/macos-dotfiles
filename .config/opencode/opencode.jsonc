{
  "$schema": "https://opencode.ai/config.json",
  "username": "Joao",
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "default_agent": "edit",
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "grep *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "tree *": "allow",
      "git fetch *": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git branch --show-current": "allow",
      "git branch -r *": "allow",
      "git branch -vv": "allow",
      "git rev-parse *": "allow",
      "git rev-list *": "allow",
      "git show *": "allow",
      "git rev-list --left-right --count": "allow",
      "gh api repos/anomalyco/opencode/releases --jq *": "allow",
      "opencode --version": "allow",
      "pnpm list *": "allow",
      "pnpm lint *": "allow",
      "pnpm type-check *": "allow",
      "pnpm prettier*": "allow",
      "opencode-whats-new.sh": "allow",
      "wc *": "allow",
    },
    "websearch": "deny",
    "codesearch": "allow",
  },
  "tools": {
    "websearch": true,
    "codesearch": true,
    "tavily_*": false,
  },
  "agent": {
    // Primary agents
    "build": {
      "model": "github-copilot/claude-sonnet-4.6",
      "color": "#C099FF",
    },
    "plan": {
      "model": "github-copilot/gpt-5.4",
      "color": "#FF966C",
      "permission": {
        "websearch": "allow",
      },
    },
    "edit": {
      "model": "github-copilot/gpt-5-mini",
      "description": "Quick edits. Use for small code changes, bug fixes, refactors, etc.",
      "mode": "primary",
      "color": "#7DFF72",
    },
    "ask": {
      "model": "github-copilot/gemini-3-flash-preview",
      "description": "Ask mode. Useful for asking questions about the codebase.",
      "mode": "primary",
      "color": "#FF0017",
      "tools": {
        "*": false,
        "read": true,
        "grep": true,
        "glob": true,
        "list": true,
        "context7_*": true,
        "tavily_*": true,
      },
      "permission": {
        "websearch": "allow",
      },
    },
    "docs": {
      "model": "github-copilot/gpt-5.4",
      "description": "ALWAYS use this when writing docs",
      "mode": "primary",
      "color": "#38A3EE",
      "prompt": "{file:./prompts/docs.txt}",
    },
    // Subagents
    "general": {
      "model": "github-copilot/claude-haiku-4.5",
    },
    "explore": {
      "model": "github-copilot/claude-haiku-4.5",
    },
    "review": {
      "model": "github-copilot/gpt-5.3-codex",
      "description": "Reviews code for quality, correctness, and best practices.",
      "mode": "subagent",
      "prompt": "{file:./prompts/review.txt}",
      "permission": {
        "edit": "ask",
        "websearch": "allow",
      },
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:TAVILY_API_KEY}",
      },
    },
  },
  "share": "manual",
}
