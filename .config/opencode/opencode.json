{
  "$schema": "https://opencode.ai/config.json",
  "username": "Joao",
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "grep *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "tree *": "allow",
      "git fetch *": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git branch --show-current": "allow",
      "git branch -r *": "allow",
      "git branch -vv": "allow",
      "git rev-parse *": "allow",
      "git rev-list *": "allow",
      "git show *": "allow",
      "git rev-list --left-right --count": "allow",
      "gh api repos/anomalyco/opencode/releases --jq *": "allow",
      "opencode --version": "allow",
      "pnpm list *": "allow",
      "pnpm lint *": "allow",
      "pnpm type-check *": "allow",
      "opencode-whats-new.sh": "allow"
    },
    "webfetch": "ask",
    "websearch": "deny"
  },
  "tools": {
    "tavily_*": false
  },
  "agent": {
    "general": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "explore": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "plan": {
      "tools": {
        "tavily_*": true
      }
    },
    "ask": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "mode": "primary",
      "color": "#FF0017",
      "tools": {
        "*": false,
        "read": true,
        "webfetch": true,
        "grep": true,
        "glob": true,
        "list": true,
        "context7_*": true,
        "tavily_*": true
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={env:TAVILY_API_KEY}",
      "enabled": false
    }
  }
}
